    <mxCell id="LEx83FIDWfh-u91xGSRo-76" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeeff;strokeColor=#0073a8;fontSize=11;align=left;verticalAlign=top;spacingTop=6;spacingLeft=8;" value="&lt;b&gt;&lt;font color=&#39;#0073a8&#39;&gt;SPF&lt;/font&gt;&lt;/b&gt;&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;✔ Verifies sending IP is authorised&lt;br&gt;✔ Checks envelope MAIL FROM domain&lt;br&gt;✖ Does NOT check From: header&lt;br&gt;✖ Breaks on forwarding&lt;br&gt;✖ Does not validate message content&lt;/font&gt;" vertex="1">
